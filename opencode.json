{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "permission": {
    "superpowers": "allow",
    "experimental.chat.system.transform": "allow",
    "external_directory": "allow"
  }
}
