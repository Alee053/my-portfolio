---
import Layout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../../styles/article-typography.css';

export async function getStaticPaths() {
    const blogs = await getCollection('blog');
    return blogs.map((blog) => ({
        params: { slug: blog.slug },
        props: { post: blog },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Filter to only h2 and h3 headings for TOC
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<Layout title={post.data.title}>
    <!-- Blog Header -->
    <section class="pt-8 md:pt-32 pb-0 px-4 md:px-8">
        <div class="mb-4 text-[10px] font-mono text-brutalist-line">[SEC // BLOG VIEWER]</div>
        <h1 class="text-4xl md:text-5xl font-bold text-brutalist-text leading-none tracking-tighter mb-6 uppercase">
            {post.data.title}
        </h1>
        <div class="flex flex-wrap gap-4 text-xs text-brutalist-line font-mono border-t border-brutalist-line pt-4 pb-8 items-center">
            <span>[{new Date(post.data.date).toLocaleDateString('en-CA')}]</span>
            {post.data.tags?.map((tag) => (
                <span class="px-2 py-0.5 border text-brutalist-text border-brutalist-line uppercase">[ {tag} ]</span>
            ))}
            {post.data.repo_url && (
                <a href={post.data.repo_url} target="_blank" rel="noopener noreferrer" class="px-3 py-1 border border-brutalist-accent text-brutalist-accent hover:bg-brutalist-accent hover:text-black transition-colors uppercase font-mono">
                    [SRC] ↗
                </a>
            )}
        </div>
    </section>

    <!-- Mobile TOC - inline at top -->
    {toc.length > 0 && (
        <div class="xl:hidden px-4 py-4 border-b border-brutalist-line">
            <div class="border border-brutalist-line p-3">
                <div class="text-[10px] font-mono text-brutalist-line mb-2">[TABLE_OF_CONTENTS]</div>
                <div class="flex flex-col gap-2">
                    {toc.map((h) => (
                        <a
                            href={`#${h.slug}`}
                            class={`text-xs font-mono hover:text-brutalist-accent transition-colors break-words ${h.depth === 3 ? 'pl-4 text-zinc-400' : 'text-zinc-300'}`}
                        >
                            {h.depth === 3 ? '└ ' : ''}{h.text}
                        </a>
                    ))}
                </div>
            </div>
        </div>
    )}

    <!-- Content with floating TOC on desktop -->
    <div class="relative bg-brutalist-bg border-t border-b border-brutalist-line">
        <!-- Floating TOC - Desktop only -->
        {toc.length > 0 && (
            <aside class="hidden xl:block absolute right-8 top-8 w-72">
                <div class="sticky top-32 border border-brutalist-line p-4 bg-brutalist-bg/95">
                    <div class="text-sm font-mono text-brutalist-line mb-3">[TABLE_OF_CONTENTS]</div>
                    <nav class="flex flex-col gap-2">
                        {toc.map((h) => (
                            <a
                                href={`#${h.slug}`}
                                class={`font-mono text-sm hover:text-brutalist-accent transition-colors ${h.depth === 3 ? 'pl-4 text-zinc-500' : 'text-zinc-300'}`}
                            >
                                {h.depth === 3 ? '└ ' : ''}{h.text}
                            </a>
                        ))}
                    </nav>
                </div>
            </aside>
        )}

        <!-- Article Content -->
        <article class="article-content px-4 md:px-8 xl:pr-[340px] pb-8">
            <Content />
        </article>
    </div>

    <!-- Back to blogs link -->
    <div class="px-4 md:px-8 py-8">
        <a
            href="/blogs"
            class="inline-flex items-center gap-2 px-4 py-2 border border-brutalist-line hover:bg-brutalist-accent hover:text-black hover:border-brutalist-accent transition-colors text-sm font-mono uppercase tracking-wider"
        >
            ← [BACK TO BROWSER]
        </a>
    </div>
</Layout>
