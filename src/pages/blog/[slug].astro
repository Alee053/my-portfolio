---
import Layout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
    const blogs = await getCollection('blog');
    return blogs.map((blog) => ({
        params: { slug: blog.slug },
        props: { post: blog },
    }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
    <section class="p-8 border-b border-brutalist-line">
        <div class="mb-4 text-[10px] font-mono text-brutalist-line">[SEC // BLOG VIEWER]</div>
        <div class="mb-4 text-xs font-bold text-brutalist-accent uppercase">
            [SYSTEM_LOG: POST_LOADED]
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-brutalist-text leading-none tracking-tighter mb-6 uppercase">
            {post.data.title}
        </h1>
        <div class="flex flex-wrap gap-4 text-xs text-brutalist-line font-mono border-t border-brutalist-line pt-4 pb-8">
            <span>[{new Date(post.data.pubDate).toLocaleDateString('en-CA')}]</span>
            {post.data.tags?.map((tag) => (
                <span class="px-2 py-0.5 border border-brutalist-line uppercase">[ {tag} ]</span>
            ))}
        </div>
    </section>
    
    {post.data.heroImage && (
        <div class="px-8 py-8">
            <Image 
                src={post.data.heroImage} 
                width={1200} 
                height={600} 
                alt={post.data.title}
                class="w-full aspect-video object-cover border border-brutalist-line"
            />
        </div>
    )}
    
    <article class="p-8 prose prose-invert prose-lg max-w-none 
        prose-headings:font-bold prose-headings:uppercase prose-headings:text-brutalist-text
        prose-h1:text-3xl prose-h1:border-b prose-h1:border-brutalist-line prose-h1:pb-4
        prose-h2:text-2xl prose-h2:border-b prose-h2:border-brutalist-line/50 prose-h2:pb-2
        prose-h3:text-xl
        prose-a:text-brutalist-accent hover:prose-a:text-brutalist-accent/80 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white prose-strong:font-bold
        prose-blockquote:border-l-brutalist-accent prose-blockquote:bg-zinc-900/50 prose-blockquote:py-1 prose-blockquote:px-4
        prose-code:bg-white/10 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-sm prose-code:font-mono
        prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-brutalist-line
        prose-img:border prose-img:border-brutalist-line
    ">
        <Content />
    </article>
    
    <div class="p-8 border-t border-brutalist-line">
        <a 
            href="/blogs"
            class="group inline-flex items-center gap-2 px-4 py-2 border border-brutalist-line hover:bg-brutalist-accent hover:text-black hover:border-brutalist-accent transition-colors text-sm font-mono uppercase tracking-wider"
        >
            ← [BACK TO BROWSER]
        </a>
    </div>
</Layout>