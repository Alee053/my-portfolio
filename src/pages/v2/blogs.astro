---
import Layout from '../../layouts/V2Layout.astro';
import BlogsBrowser from '../../components/v2/BlogsBrowser.svelte';
import { getCollection } from 'astro:content';

const blogsData = (await getCollection('blog')).map(blog => ({
    title: blog.data.title,
    description: blog.data.description || '',
    tags: blog.data.tags || [],
    slug: blog.slug,
    pubDate: blog.data.pubDate
}));
---

<Layout title="Blogs">
    <BlogsBrowser blogs={blogsData} client:load />
</Layout>