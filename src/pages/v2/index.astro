---
import Layout from '../../layouts/V2Layout.astro';
import { getCollection } from 'astro:content';
const projects = (await getCollection('projects')).slice(0, 3);
const blogs = (await getCollection('blog')).sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()).slice(0, 3);
---
<Layout title="Alejandro Castro">
    <section>
        <div class="mb-4 text-[10px] font-mono text-brutalist-line" data-purpose="section-label">
            [SEC 01 // HERO]
        </div>
        <div class="border-l-4 border-brutalist-line pl-8">
            <h1 class="text-7xl md:text-9xl font-bold tracking-tighter leading-none mb-4 uppercase font-sans" data-hero="name">
                ALEJANDRO<br>
                CASTRO
            </h1>
            <p class="max-w-md font-mono text-sm leading-relaxed text-zinc-500" data-hero="subtitle">
                AI RESEARCHER & SYSTEM ARCHITECT. FOCUSING ON NEURAL SYMBOLIC REASONING AND AUTONOMOUS AGENT TOPOLOGIES.
            </p>
        </div>
    </section>
    <div class="mt-20 w-full h-px dashed-line relative">
        <span class="absolute -top-3 right-0 text-[10px] font-mono text-brutalist-line">[LAYOUT GRID X-72]</span>
    </div>
    <!-- Recent Projects Teaser -->
    <section class="mt-32 pb-40">
        <div class="flex justify-between items-end mb-12">
            <div>
                <div class="text-[10px] font-mono text-brutalist-line mb-2">[SEC 02 // RECENT_WORK]</div>
                <h2 class="text-4xl font-light uppercase tracking-widest">Projects</h2>
            </div>
            <a href="/v2/projects" class="text-xs font-mono text-brutalist-line hover:text-white transition-colors">[VIEW ALL]</a>
        </div>
        <div class="border-t border-brutalist-line">
            {projects.map((project, index) => (
                    <div class="grid grid-cols-12 py-6 border-b border-dashed border-brutalist-line group hover:bg-zinc-900/50 transition-colors cursor-crosshair">
                        <div class="col-span-1 font-mono text-xs text-brutalist-line">{String(index + 1).padStart(2, '0')}.</div>
                        <div class="col-span-7">
                            <h3 class="text-xl font-bold uppercase">{project.data.name}</h3>
                            <p class="text-xs font-mono text-zinc-500 mt-1">{project.data.subtitle || ''}</p>
                        </div>
                        <div class="col-span-4 text-right font-mono text-[10px]">
                            {project.data.tags?.map((tag) => (
                                    <span class="px-2 py-0.5 border border-brutalist-line ml-2">[ {tag.toUpperCase()} ]</span>
                            )) || ''}
                        </div>
                    </div>
            ))}
        </div>
    </section>
    <!-- Recent Blogs Teaser -->
    {blogs.length > 0 && (
    <section class="mt-20 pb-20">
        <div class="flex justify-between items-end mb-12">
            <div>
                <div class="text-[10px] font-mono text-brutalist-line mb-2">[SEC 03 // RECENT_BLOGS]</div>
                <h2 class="text-4xl font-light uppercase tracking-widest">Blogs</h2>
            </div>
            <a href="/v2/blogs" class="text-xs font-mono text-brutalist-line hover:text-white transition-colors">[VIEW ALL]</a>
        </div>
        <div class="border-t border-brutalist-line">
            {blogs.map((blog, index) => (
                    <div class="grid grid-cols-12 py-6 border-b border-dashed border-brutalist-line group hover:bg-zinc-900/50 transition-colors cursor-pointer" onclick={`window.location.href='/v2/blog/${blog.slug}'`}>
                        <div class="col-span-2 font-mono text-[10px] text-zinc-500">{new Date(blog.data.pubDate).toISOString().slice(0,10)}</div>
                        <div class="col-span-10">
                            <h3 class="text-lg font-bold uppercase group-hover:text-brutalist-accent transition-colors">{blog.data.title}</h3>
                            <p class="text-xs font-mono text-zinc-400 mt-1 max-w-2xl">{blog.data.description?.slice(0, 100)}...</p>
                        </div>
                    </div>
            ))}
        </div>
    </section>
    )}
</Layout>

<script>
    import { gsap } from 'gsap';
    
    document.addEventListener('DOMContentLoaded', () => {
        const heroName = document.querySelector('[data-hero="name"]');
        const heroSubtitle = document.querySelector('[data-hero="subtitle"]');
        
        if (heroName && heroSubtitle) {
            gsap.from([heroName, heroSubtitle], {
                y: 20,
                opacity: 0,
                duration: 0.8,
                ease: 'power3.out',
                stagger: 0.1
            });
        }
    });
</script>