---
import Layout from '../layouts/BaseLayout.astro';
import BlogsBrowser from '../components/BlogsBrowser.svelte';
import { getCollection } from 'astro:content';

const blogsData = (await getCollection('blog')).map(blog => ({
    title: blog.data.title,
    description: blog.data.description || '',
    tags: blog.data.tags || [],
    slug: blog.slug,
    date: blog.data.date
}));
---

<Layout title="BLOGS">
    <BlogsBrowser blogs={blogsData} client:load />
</Layout>