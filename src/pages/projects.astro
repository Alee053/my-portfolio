---
import Layout from '../layouts/BaseLayout.astro';
import ProjectsBrowser from '../components/ProjectsBrowser.svelte';
import { getCollection } from 'astro:content';

const projectsData = (await getCollection('projects')).map(project => ({
    slug: project.slug,
    title: project.data.name,
    subtitle: project.data.subtitle || '',
    tags: project.data.tags || [],
    github_url: project.data.link || '',
    blog_slug: project.data.blog_slug || '',
    demo_url: project.data.demo_url || ''
}));
---

<Layout title="PROJECTS">
    <ProjectsBrowser projects={projectsData} client:load />
</Layout>