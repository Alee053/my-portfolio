---
import '../styles/brutalist.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/liberation-mono" rel="stylesheet">

  <slot name="head" />
</head>
<body class="bg-brutalist-bg text-brutalist-text font-sans relative min-h-screen">
  <!-- Background Grid - scrolls with content -->
  <div class="absolute inset-0 pointer-events-none blueprint-grid opacity-20 z-0" style="min-height: 100vh;"></div>
  <!-- Arbitrary lines - scroll with content -->
  <div class="absolute top-0 left-1/4 h-full solid-line-v z-0" style="min-height: 100vh;"></div>
  <div class="absolute top-1/3 left-0 w-full solid-line-h z-0"></div>
  <!-- Header -->
  <header class="sticky top-0 z-20 flex justify-between items-start p-8 border-b border-brutalist-line bg-brutalist-bg/80 backdrop-blur-sm">
    <div class="text-[10px] font-mono tracking-widest uppercase" data-purpose="technical-annotation">
      [REF: AC-2026-BRUTALIST] <br/>
      TS: 2026.03.17_04:30
    </div>
    <nav class="flex gap-6 font-mono text-sm">
      <a class="hover:text-white transition-colors" href="/v2/">[HOME]</a>
      <a class="hover:text-white transition-colors underline decoration-brutalist-accent cursor-pointer" onclick="toggleAboutModal(); return false;" href="javascript:void(0)">[ABOUT ME]</a>
      <a class="hover:text-white transition-colors" href="/v2/projects">[PROJECTS]</a>
      <a class="hover:text-white transition-colors" href="/v2/blogs">[BLOGS]</a>
    </nav>
  </header>
  <main class="relative z-10 min-h-screen pt-32 px-8 pb-40" style="min-height: 100vh;">
    <slot />
  </main>
  <!-- Footer -->
  <footer class="border-t border-brutalist-line p-8 flex justify-between items-center">
    <div class="text-[10px] font-mono uppercase tracking-wider">
      © 2026 ALEJANDRO CASTRO // ALL RIGHTS RESERVED
    </div>
    <div class="flex gap-4">
      <div class="w-3 h-3 bg-brutalist-line"></div>
      <div class="w-3 h-3 bg-zinc-700"></div>
      <div class="w-3 h-3 bg-zinc-500"></div>
    </div>
  </footer>
  <!-- About Modal -->
  <aside id="about-modal" class="fixed top-0 right-0 w-full md:w-1/3 h-full bg-brutalist-bg border-l border-brutalist-line z-50 p-10 flex flex-col shadow-2xl" style="transform: translateX(100%);">
    <div class="flex justify-between items-center mb-10">
      <div class="text-[10px] font-mono">[MODAL: ABOUT_ME]</div>
      <button class="text-xl hover:text-white cursor-pointer" onclick="toggleAboutModal()">[X]</button>
    </div>
    <div class="flex-grow font-mono text-sm leading-relaxed overflow-y-auto pr-4">
      <p class="mb-6">
        <span class="text-brutalist-line mr-2">// ORIGIN:</span>
        Alejandro Castro is a software engineer and AI enthusiast based in the world of code and innovation.
      </p>
      <p class="mb-6">
        <span class="text-brutalist-line mr-2">// FOCUS:</span>
        Building full-stack applications, AI/ML projects, and contributing to open-source with a brutalist aesthetic.
      </p>
      <div class="mt-12 space-y-4">
        <div class="flex justify-between border-b border-brutalist-line pb-1">
          <span>EDUCATION</span>
          <span class="text-zinc-500">SOFTWARE ENGINEER</span>
        </div>
        <div class="flex justify-between border-b border-brutalist-line pb-1">
          <span>STATUS</span>
          <span class="text-green-500 text-[10px]">● ACTIVE</span>
        </div>
      </div>
      <div class="mt-20">
        <div class="text-[10px] text-brutalist-line mb-4">[SYSTEM_LOGS]</div>
        <div class="text-[10px] font-mono text-zinc-600 space-y-1">
          <p>&gt; Initialize connection...</p>
          <p>&gt; Loading biography.v2.dat</p>
          <p>&gt; Parsing credentials</p>
          <p>&gt; Rendering view... OK</p>
        </div>
      </div>
    </div>
    <div class="mt-10 border-t border-brutalist-line pt-6">
      <button class="w-full bg-zinc-800 hover:bg-brutalist-accent hover:text-white py-3 font-mono text-xs uppercase tracking-widest transition-colors">
        Download CV
      </button>
    </div>
  </aside>
  <script>
    import { gsap } from 'gsap';
    
    let isModalOpen = false;
    
    function toggleAboutModal() {
      const modal = document.getElementById('about-modal');
      
      if (!isModalOpen) {
        gsap.to(modal, {
          x: '0%',
          duration: 0.5,
          ease: 'power3.out'
        });
        isModalOpen = true;
      } else {
        gsap.to(modal, {
          x: '100%',
          duration: 0.4,
          ease: 'power3.in'
        });
        isModalOpen = false;
      }
    }
  </script>
</body>
</html>