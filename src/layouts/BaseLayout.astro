---
import '../styles/globals.css';
import Navbar from '../components/Navbar.svelte';
import ContactModal from '../components/ContactModal.svelte';
import AboutModal from '../components/AboutModal.svelte';
import Splash from '../components/Splash.astro';
import SEO from '../components/SEO.astro';
import { SITE } from '../lib/site';
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: 'website' | 'article';
    publishDate?: Date;
    showSplash?: boolean;
}

const {
    title,
    description = 'Portfolio of Alejandro Castro — AI researcher and systems engineering student focused on reinforcement learning, algorithms, and search-based planning.',
    image,
    type,
    publishDate,
    showSplash = false,
} = Astro.props;

const fullTitle = title ? `${title} | ALEJANDRO CASTRO` : 'ALEJANDRO CASTRO';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" href="/logo.png" />
  <script is:inline>document.documentElement.classList.add('js');</script>
  <title>{fullTitle}</title>
  <SEO title={fullTitle} description={description} image={image} type={type} publishDate={publishDate} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.cdnfonts.com/css/liberation-mono" rel="stylesheet">
  <ClientRouter />

  <slot name="head" />
</head>
<body class="bg-brutalist-bg text-brutalist-text font-sans relative min-h-screen">
  {showSplash && <Splash />}
  <a href="#main" class="skip-link">[SKIP TO CONTENT]</a>
  <!-- Background Grid - scrolls with content -->
  <div class="absolute inset-0 pointer-events-none blueprint-grid opacity-40 z-0" style="min-height: 100vh;"></div>

  <!-- Viewport decoration: corner crosshairs + live dimensions -->
  <div aria-hidden="true">
    <div class="crosshair crosshair-tl"></div>
    <div class="crosshair crosshair-tr"></div>
    <div class="crosshair crosshair-br"></div>
    <div class="crosshair crosshair-bl"></div>
    <div class="viewport-label" id="viewport-label"></div>
  </div>

  <!-- Navbar -->
  <Navbar client:load transition:persist="navbar" />

  <main id="main" class="relative z-10 min-h-screen pt-32 md:px-8 pb-20 px-4" style="min-height: 100vh;">
    <slot />
  </main>
  <!-- Footer -->
  <footer class="border-t border-brutalist-line p-4 md:p-8 flex justify-between items-center">
    <div class="text-[10px] font-mono uppercase tracking-wider">
      © {new Date().getFullYear()} ALEJANDRO CASTRO // ALL RIGHTS RESERVED
    </div>
    <div class="flex gap-4">
      <div class="w-3 h-3 bg-brutalist-line"></div>
      <div class="w-3 h-3 bg-zinc-700"></div>
      <div class="w-3 h-3 bg-zinc-500"></div>
    </div>
  </footer>
  <!-- About Modal -->
  <AboutModal client:load transition:persist="about-modal" />

  <!-- Contact Modal -->
  <ContactModal client:load transition:persist="contact-modal" githubUrl={SITE.github} linkedInUrl={SITE.linkedin} email={SITE.email} />
  
  <script>
    function toggleAboutModal() {
      document.dispatchEvent(new CustomEvent('close-toggle-contact-modal'));
      document.dispatchEvent(new CustomEvent('toggle-about-modal'));
    }
    
    function toggleContactModal() {
      document.dispatchEvent(new CustomEvent('close-toggle-about-modal'));
      document.dispatchEvent(new CustomEvent('toggle-contact-modal'));
    }
    
    // @ts-ignore
    window.toggleAboutModal = toggleAboutModal;
    // @ts-ignore
    window.toggleContactModal = toggleContactModal;
  </script>

  <script>
    import { initReveal } from '../lib/reveal';

    let viewportLabel: HTMLElement | null = null;
    let rafId = 0;

    function updateViewportLabel() {
      if (viewportLabel) {
        viewportLabel.textContent = `[VIEWPORT: ${window.innerWidth}x${window.innerHeight}]`;
      }
    }

    window.addEventListener('resize', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updateViewportLabel);
    });

    function initPage() {
      viewportLabel = document.getElementById('viewport-label');
      updateViewportLabel();
      initReveal();
    }

    initPage();
    // Re-init after client-side navigations once ClientRouter is present
    document.addEventListener('astro:page-load', initPage);
  </script>
</body>
</html>
